{
  "1407921": [
    {
      "t": 31.25,
      "text": "か細い火が 心の端に灯る"
    },
    {
      "t": 35.72,
      "text": "いつの間にか 燃え広がる熱情"
    },
    {
      "t": 40.26,
      "text": "私の蝶 不規則に飛び回り"
    },
    {
      "t": 44.78,
      "text": "あなたの手に 鱗粉を付けた"
    },
    {
      "t": 49.16,
      "text": "絡み合う指 ほどいて"
    },
    {
      "t": 53.49,
      "text": "唇から 舌へと"
    },
    {
      "t": 57.97,
      "text": "許されない事ならば"
    },
    {
      "t": 61.76,
      "text": "尚更 燃え上がるの"
    },
    {
      "t": 66.59,
      "text": "抱き寄せて欲しい 確かめて欲しい"
    },
    {
      "t": 70.45,
      "text": "間違いなど無いんだと 思わせて"
    },
    {
      "t": 75.82,
      "text": "キスをして 塗り替えて欲しい"
    },
    {
      "t": 79.42,
      "text": "魅惑の時に 酔いしれ 溺れていたいの"
    },
    {
      "t": 87.25,
      "text": ""
    },
    {
      "t": 93.49,
      "text": "束縛して もっと必要として"
    },
    {
      "t": 98.07,
      "text": "愛しいなら 執着を見せつけて"
    },
    {
      "t": 102.55,
      "text": "「おかしい」のが たまらなく 好きになる"
    },
    {
      "t": 106.97,
      "text": "行けるトコまで 行けばいいよ"
    },
    {
      "t": 111.15,
      "text": "迷い込んだ心なら"
    },
    {
      "t": 115.35,
      "text": "簡単に 融けてゆく"
    },
    {
      "t": 120.21,
      "text": "優しさなんて 感じる暇など 無い位に"
    },
    {
      "t": 128.96,
      "text": "繰り返したのは あの夢じゃなくて"
    },
    {
      "t": 132.72,
      "text": "紛れも無い 現実の私達"
    },
    {
      "t": 137.87,
      "text": "触れてから 戻れないと知る"
    },
    {
      "t": 141.74,
      "text": "それでいいの 誰よりも 大切な あなた"
    },
    {
      "t": 151.35,
      "text": ""
    },
    {
      "t": 164.68,
      "text": "夜明けが来ると 不安で"
    },
    {
      "t": 168.72,
      "text": "泣いてしまう 私に"
    },
    {
      "t": 173.54,
      "text": "「大丈夫」と囁いた"
    },
    {
      "t": 177.12,
      "text": "あなたも 泣いていたの？"
    },
    {
      "t": 182.51,
      "text": "抱き寄せて欲しい 確かめて欲しい"
    },
    {
      "t": 186.76,
      "text": "間違いなど無いんだと 思わせて"
    },
    {
      "t": 191.86,
      "text": "キスをして 塗り替えて欲しい"
    },
    {
      "t": 195.45,
      "text": "魅惑の時に 酔いしれ 溺れたい"
    },
    {
      "t": 200.71,
      "text": "引き寄せて マグネットのように"
    },
    {
      "t": 204.68,
      "text": "例え いつか離れても 巡り会う"
