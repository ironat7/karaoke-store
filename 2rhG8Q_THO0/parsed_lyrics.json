{
  "11376653": [
    {
      "t": 44.08,
      "text": "朝まで踊る 夢だけ見せて"
    },
    {
      "t": 47.17,
      "text": "時計の鐘が解く魔法"
    },
    {
      "t": 50.32,
      "text": "曖昧な指 誘う階段"
    },
    {
      "t": 53.72,
      "text": "三段飛ばしに跳ねていく"
    },
    {
      "t": 58.27,
      "text": "馬車の中で震えてた"
    },
    {
      "t": 63.56,
      "text": "みじめな古着"
    },
    {
      "t": 65.24,
      "text": "めくり廻れ 夜の舞踏"
    },
    {
      "t": 71.66,
      "text": "見知らぬ顔探す"
    },
    {
      "t": 75.02,
      "text": "囁くあの声が"
    },
    {
      "t": 77.87,
      "text": "握り締めた刃衝きたて"
    },
    {
      "t": 82.18,
      "text": "全てを奪えと"
    },
    {
      "t": 84.76,
      "text": "孤児集う城"
    },
    {
      "t": 88.05,
      "text": "笑み仮面に描いて"
    },
    {
      "t": 91.13,
      "text": "偽りの慈しみさえ"
    },
    {
      "t": 95.24,
      "text": "羽で包む熾天使"
    },
    {
      "t": 110.8,
      "text": "灰の中で赤く溶けて"
    },
    {
      "t": 117.48,
      "text": "混じる硝子の靴"
    },
    {
      "t": 124.04,
      "text": "今更帰る 震えているの"
    },
    {
      "t": 127.29,
      "text": "貴方が目をやる時計"
    },
    {
      "t": 130.53,
      "text": "靴脱ぎ踊る スロープ抜けて"
    },
    {
      "t": 133.78,
      "text": "喉まで伸びる 指の先で"
    },
    {
      "t": 138.01,
      "text": "すくう雫 口付けて"
    },
    {
      "t": 143.46,
      "text": "走る衝動"
    },
    {
      "t": 145.15,
      "text": "背骨抜けていく刹那"
    },
    {
      "t": 151.56,
      "text": "鐘は鳴らさないで"
    },
    {
      "t": 154.92,
      "text": "貴方に跪き"
    },
    {
      "t": 158.15,
      "text": "まだダメと叫んだ右手が"
    },
    {
      "t": 162.14,
      "text": "突き刺すさよなら"
    },
    {
      "t": 164.82,
      "text": "消せない硝煙を"
    },
    {
      "t": 168.04,
      "text": "香水にまとう姫"
    },
    {
      "t": 171.0,
      "text": "強い瞳 僕の凍った"
    },
    {
      "t": 175.2,
      "text": "仮面ごと撃ち抜く"
    },
    {
      "t": 184.41,
      "text": "今も耳に貴方の吐息が"
    },
    {
      "t": 190.72,
      "text": "突き刺さるの 遠い夢"
    },
    {
      "t": 197.33,
      "text": "ステンドグラスごし光る月が"
    },
    {
      "t": 203.89,
      "text": "君にかぶせたベール"
    },
    {
      "t": 210.58,
      "text": "ドレス膝で裂いて"
    },
    {
      "t": 213.67,
      "text": "ティアラは投げ捨てて"
    },
    {
      "t": 216.75,
      "text": "見つめあう瞳と瞳が"
    },
    {
      "t": 220.9,
      "text": "火花を放つ"
    },
    {
      "t": 223.53,
      "text": "孤独な魂が"
    },
    {
      "t": 226.74,
      "text": "炎あげ惹かれあう"
    },
    {
      "t": 229.86,
      "text": "その涙救えないなら"
    },
    {
      "t": 233.89,
      "text": "まるで一人遊び"
    },
    {
      "t": 236.78,
      "text": "時よ止まれ今は"
    },
    {
      "t": 239.9,
      "text": "貴方に酔いしれて"
    },
    {
      "t": 242.99,
      "text": "揺れる鼓動一つ一つを"
    },
    {
      "t": 246.86,
      "text": "刻み付けてたい"
    },
    {
      "t": 249.74,
      "text": "とどまれ 熱く濡れ"
    },
    {
      "t": 253.09,
      "text": "打ち付ける 昂まりに"
    },
    {
      "t": 256.09,
      "text": "これ以上は動けないよ"
    },
    {
      "t": 260.03,
      "text": "まるで御伽噺"
    }
  ]
}