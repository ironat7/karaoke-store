{
  "14510386": [
    {
      "t": 0.06,
      "text": "あの日と同じ 星を僕ら 目印にして 声を重ねた"
    },
    {
      "t": 11.97,
      "text": ""
    },
    {
      "t": 30.15,
      "text": "浮かび上がった憧憬 濃く滲んでいた後悔も"
    },
    {
      "t": 34.73,
      "text": "自分らしく話せたのなら どんなに楽だろう"
    },
    {
      "t": 40.66,
      "text": "ねぇどんな音で 夢を鳴らしたらいい？"
    },
    {
      "t": 44.54,
      "text": "分かっていたんだ 立ち止まっていたのは僕の方だろう"
    },
    {
      "t": 49.5,
      "text": "零れ落ちた何気ない言葉たち 大事にしてあげられなかった"
    },
    {
      "t": 60.36,
      "text": "見て見ぬフリしたって ここにいるんだよってまだ"
    },
    {
      "t": 65.17,
      "text": "叫んでる ねえ"
    },
    {
      "t": 68.81,
      "text": "なんで笑ってるんだろう 何一つ"
    },
    {
      "t": 72.49,
      "text": "言いたい想いも 書き出せないくせに"
    },
    {
      "t": 75.75,
      "text": "(変わりたい 進みたい)"
    },
    {
      "t": 77.71,
      "text": "気付けたんだ"
    },
    {
      "t": 79.44,
      "text": "音にのせて 流れてく一筋の光に"
    },
    {
      "t": 84.01,
      "text": "僕らもなれるから (かまわない 進もう)"
    },
    {
      "t": 87.77,
      "text": "伝えるんだ 今"
    },
    {
      "t": 91.03,
      "text": ""
    },
    {
      "t": 101.39,
      "text": "聞こえている？ この声が"
    },
    {
      "t": 106.07,
      "text": ""
    },
    {
      "t": 115.19,
      "text": "積もり積もった投影 拙く歪んだ防衛も"
    },
    {
      "t": 119.49,
      "text": "自分らしく解けたのなら どんなに楽だろう"
    },
    {
      "t": 125.72,
      "text": "ねぇどんな詩で 僕を晒したらいい？"
    },
    {
      "t": 129.73,
      "text": "独りぼっち 涙堪えていたのは過去の僕だ"
    },
    {
      "t": 134.68,
      "text": "崩れ落ちたしょうもないプライドたち 逃げ出したくてたまらなかった"
    },
    {
      "t": 145.25,
      "text": "ただ傍にいるよって 信じてるんだよってほら"
    },
    {
      "t": 150.04,
      "text": "聞こえている ねえ"
    },
    {
      "t": 153.9,
      "text": "なんで迷ってるんだろう 何一つ"
    },
    {
      "t": 157.29,
      "text": "捨てられるような想いなどないのでしょう？"
    },
    {
      "t": 160.72,
      "text": "(叶えたい 届けたい)"
    },
    {
      "t": 162.48,
      "text": "抱えて行くんだ"
    },
    {
      "t": 164.65,
      "text": "歌にのせて 世界中駆け巡る音に"
    },
    {
      "t": 169.02,
      "text": "僕らもなれるかな (大丈夫 進もう)"
    },
    {
      "t": 172.71,
      "text": "登っていくんだ"
    },
    {
      "t": 175.5,
      "text": ""
    },
    {
      "t": 194.62,
      "text": "僕ら"
    },
    {
      "t": 195.79,
      "text": "日が沈むまで笑い合った 星を見に夜を走った"
    },
    {
      "t": 200.77,
      "text": "先なんてどうでも良かった あの気持ちを"
    },
    {
      "t": 205.25,
      "text": "忘れないで 忘れないよ ずっと"
    },
    {
      "t": 214.44,
      "text": "変わっていくもの 過ぎるもの"
    },
    {
      "t": 217.31,
      "text": "誰も止めることなんて出来やしないから"
    },
    {
      "t": 222.45,
      "text": "出来やしないけど"
    },
    {
      "t": 224.4,
      "text": "この瞬間に 生きている"
    },
    {
      "t": 227.28,
      "text": "逃せない「今」を 見つけ出したいから"
    },
    {
      "t": 231.36,
      "text": "ここにいるんだ"
    },
    {
      "t": 234.58,
      "text": "響かせたいよ この歌を"
    },
    {
      "t": 237.34,
      "text": "待っている誰かがそこにいるのなら"
    },
    {
      "t": 240.78,
      "text": "(奏でよう 伝えよう)"
    },
    {
      "t": 242.32,
      "text": "生まれたセカイで"
    },
    {
      "t": 244.75,
      "text": "声にのせて 暗い夜の"
    },
    {
      "t": 247.76,
      "text": "空で僕らまだ弱くても"
    },
    {
      "t": 250.81,
      "text": "光るから 伝えるんだ 今"
    },
    {
      "t": 258.83,
      "text": ""
    },
    {
      "t": 278.85,
      "text": "聞こえてる？ この声が"
    },
    {
      "t": 283.65,
      "text": ""
    }
  ]
}