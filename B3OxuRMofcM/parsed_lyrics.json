  "11030591": [
    {
      "t": 7.22,
      "text": "にゃー！ Hello! The beautiful days!"
    },
    {
      "t": 9.5,
      "text": "刮目しちゃってくれ！"
    },
    {
      "t": 11.56,
      "text": "Please call \"Elite\"!"
    },
    {
      "t": 15.92,
      "text": "Funky dancing, baby! A-ah, ah!"
    },
    {
      "t": 26.73,
      "text": "さぁ 待ったはなしだ！ 始めちゃえ！"
    },
    {
      "t": 29.35,
      "text": "今日も 気ぃ引き締めて えいや！ で挑戦だ"
    },
    {
      "t": 32.7,
      "text": "躊躇は厳禁 足踏みしてないで"
    },
    {
      "t": 36.11,
      "text": "一緒に「せぇの！」でもっと 前に行こう ね？"
