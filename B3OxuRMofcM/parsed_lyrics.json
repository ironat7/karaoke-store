  "11380277": [
    {
      "t": 20.27,
      "text": "まだ云わないで 呪文めいたその言葉"
    },
    {
      "t": 23.57,
      "text": "\"愛\"なんて羽のように軽い"
    },
    {
      "t": 27.14,
      "text": "囁いて パパより優しいテノールで"
    },
    {
      "t": 30.67,
      "text": "奪う覚悟があるのならば"
    },
    {
      "t": 37.91,
      "text": "百万の薔薇の寝台に 埋もれ見る夢よりも"
    },
    {
      "t": 45.16,
      "text": "馨しく私は生きてるの (生きてるの)"
    },
    {
      "t": 52.18,
      "text": "どうすれば醜いものが 蔓延ったこの世界"
    },
    {
      "t": 59.16,
      "text": "汚れずに羽博いて行けるのか (行けるのか)"
    },
    {
      "t": 65.76,
      "text": "ひとり繭の中 学びつづけても"
    },
    {
      "t": 72.74,
      "text": "水晶の星空は 遠すぎるの"
    },
    {
      "t": 83.14,
      "text": "まだ触れないで その慄える指先は"
    },
    {
      "t": 86.6,
      "text": "花盗人の甘い躊躇い"
    },
    {
      "t": 90.18,
      "text": "触れてもいい この深い胸の奥にまで"
    },
    {
      "t": 93.75,
      "text": "届く自信があるのならば"
    },
    {
      "t": 99.29,
      "text": "白馬の王子様なんか 信じてるわけじゃない"
    },
    {
      "t": 106.08,
      "text": ""
    },
    {
      "t": 116.83,
      "text": "ひび割れたガラスケースに 飾られた純潔は"
    },
    {
      "t": 124.08,
      "text": "滅びゆく天使たちの心臓 (心臓)"
    },
    {
      "t": 130.91,
      "text": "また明日も目覚めるたびに 百年の刻を知る"
    },
    {
      "t": 137.87,
      "text": "眠れない魂の荊姫 (荊姫)"
    },
    {
      "t": 144.85,
      "text": "くい込む冠 一雫の血に"
    },
    {
      "t": 151.76,
      "text": "ああ 現実が真実と 思い知るの"
    },
    {
      "t": 162.03,
      "text": "まだ行かないで 月光の結界で"
    },
    {
      "t": 165.55,
      "text": "過ちに気づいてしまいそう"
    },
    {
      "t": 169.03,
      "text": "安らかなぬくもりに抱かれ"
    },
    {
      "t": 171.72,
      "text": "壊れたい私は 罪の子なのでしょうか"
    },
    {
      "t": 177.84,
      "text": "そっと零れてくる 涙の意味さえわからない"
    },
    {
      "t": 188.89,
      "text": ""
    },
    {
      "t": 221.6,
      "text": "もう云わないで 呪文めいたその言葉"
    },
    {
      "t": 225.0,
      "text": "\"愛\"なんて鎖のように重い"
    },
    {
      "t": 228.51,
      "text": "囁いて パパより優しいテノールで"
    },
    {
      "t": 231.92,
      "text": "どんな覚悟もできるならば"
    },
    {
      "t": 235.53,
      "text": "さあ誓ってよ その震える唇で"
    },
    {
      "t": 238.99,
      "text": "蜜を摘む狩人のときめき"
    },
    {
      "t": 242.48,
      "text": "攫っていい この深い胸の奥底を"
    },
    {
      "t": 246.17,
      "text": "射抜く勇気があるのならば"
    },
    {
      "t": 251.45,
      "text": "貴方 捕まえたらけして 逃がさないようにして"
    },
    {
      "t": 263.3,
      "text": ""
    }
  ],
