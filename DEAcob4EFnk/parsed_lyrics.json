{
  "1408128": [
    {
      "t": 12.32,
      "text": "私の恋を悲劇のジュリエットにしないで"
    },
    {
      "t": 18.83,
      "text": "ここから連れ出して..."
    },
    {
      "t": 23.28,
      "text": "そんな気分よ"
    },
    {
      "t": 27.04,
      "text": ""
    },
    {
      "t": 35.94,
      "text": "パパとママにおやすみなさい"
    },
    {
      "t": 38.61,
      "text": "せいぜい いい夢をみなさい"
    },
    {
      "t": 41.52,
      "text": "大人はもう寝る時間よ"
    },
    {
      "t": 47.13,
      "text": "咽返（むせかえ）る魅惑のキャラメル"
    },
    {
      "t": 49.98,
      "text": "恥じらいの素足をからめる"
    },
    {
      "t": 52.87,
      "text": "今夜はどこまでいけるの？"
    },
    {
      "t": 57.55,
      "text": "噛みつかないで 優しくして"
    },
    {
      "t": 60.59,
      "text": "苦いものはまだ嫌いなの"
    },
    {
      "t": 63.33,
      "text": "ママの作るお菓子ばかり食べたせいね"
    },
    {
      "t": 68.87,
      "text": "知らないことがあるのならば"
    },
    {
      "t": 71.96,
      "text": "知りたいと思う普通でしょ？"
    },
    {
      "t": 74.65,
      "text": "全部見せてよ"
    },
    {
      "t": 76.33,
      "text": "あなたにならば見せてあげる私の..."
    },
    {
      "t": 82.15,
      "text": "ずっと恋しくてシンデレラ"
    },
    {
      "t": 84.64,
      "text": "制服だけで駆けていくわ"
    },
    {
      "t": 87.9,
      "text": "魔法よ時間を止めてよ"
    },
    {
      "t": 90.36,
      "text": "悪い人に 邪魔されちゃうわ"
    },
    {
      "t": 93.27,
      "text": "逃げ出したいのジュリエット"
    },
    {
      "t": 96.11,
      "text": "でもその名前で呼ばないで"
    },
    {
      "t": 99.28,
      "text": "そうよね 結ばれなくちゃね"
    },
    {
      "t": 101.65,
      "text": "そうじゃないと楽しくないわ"
    },
    {
      "t": 104.91,
      "text": "ねぇ私と生きてくれる？"
    },
    {
      "t": 111.23,
      "text": ""
    },
    {
      "t": 122.23,
      "text": "背伸びをした長いマスカラ"
    },
    {
      "t": 125.11,
      "text": "いい子になるよきっと明日から"
    },
    {
      "t": 127.87,
      "text": "今だけ私を許して"
    },
    {
      "t": 133.69,
      "text": "黒いレースの境界線"
    },
    {
      "t": 136.39,
      "text": "守る人は今日はいません"
    },
    {
      "t": 139.29,
      "text": "越えたらどこまでいけるの？"
    },
    {
      "t": 144.12,
      "text": "噛みつくほどに 痛いほどに"
    },
    {
      "t": 147.03,
      "text": "好きになってたのは私でしょ"
    },
    {
      "t": 149.99,
      "text": "パパはでもねあなたのこと嫌いみたい"
    },
    {
      "t": 155.25,
      "text": "私のためと差し出す手に"
    },
    {
      "t": 158.45,
      "text": "握ってるそれは首輪でしょ"
    },
    {
      "t": 161.2,
      "text": "連れ出してよ 私のロミオ"
    },
    {
      "t": 164.69,
      "text": "叱られるほど遠くへ"
    },
    {
      "t": 168.52,
      "text": "鐘が鳴り響くシンデレラ"
    },
    {
      "t": 171.08,
      "text": "ガラスの靴は置いていくわ"
    },
    {
      "t": 174.25,
      "text": "だからね 早く見つけてね"
    },
    {
      "t": 176.72,
      "text": "悪い夢に 焦らされちゃうわ"
    },
    {
      "t": 179.71,
      "text": "きっとあの子もそうだった"
    },
    {
      "t": 182.42,
      "text": "落としたなんて嘘をついた"
    },
    {
      "t": 185.59,
      "text": "そうよね 私も同じよ"
    },
    {
      "t": 187.97,
      "text": "だってもっと愛されたいわ"
    },
    {
      "t": 191.05,
      "text": "ほら 私はここにいるよ"
    },
    {
      "t": 197.06,
      "text": ""
    },
    {
      "t": 208.44,
      "text": "私の心そっと覗いてみませんか"
    },
    {
      "t": 214.01,
      "text": "欲しいものだけあふれかえっていませんか"
    },
    {
      "t": 219.85,
      "text": "まだ別腹よもっともっとぎゅっと詰め込んで"
    },
    {
      "t": 225.4,
      "text": "いっそあなたの居場所までも埋めてしまおうか"
    },
    {
      "t": 230.88,
      "text": "でもそれじゃ意味ないの"
    },
    {
      "t": 236.06,
      "text": "大きな箱より 小さな箱に幸せはあるらしい"
    },
    {
      "t": 242.08,
      "text": "どうしよこのままじゃ私は"
    },
    {
      "t": 244.74,
      "text": "あなたに嫌われちゃうわ"
    },
    {
      "t": 247.48,
      "text": "でも私より欲張りなパパとママは今日も変わらず"
    },
    {
      "t": 253.22,
      "text": "そうよね 素直でいいのね"
    },
    {
      "t": 255.75,
      "text": "落としたのは金の斧でした"
    },
    {
      "t": 258.96,
      "text": "嘘つきすぎたシンデレラ"
    },
    {
      "t": 261.32,
      "text": "オオカミに食べられたらしい"
    },
    {
      "t": 264.65,
      "text": "どうしようこのままじゃ私も"
    },
    {
      "t": 267.45,
      "text": "いつかは食べられちゃうわ"
    },
    {
      "t": 270.33,
      "text": "その前に助けに来てね"
    },
    {
      "t": 274.74,
      "text": ""
    }
  ]
}