{
  "4760145": [
    {
      "t": 0.52,
      "text": " 私の恋を悲劇のジュリエットにしないで"
    },
    {
      "t": 8.09,
      "text": " ここから連れ出して..."
    },
    {
      "t": 12.23,
      "text": " そんな気分よ"
    },
    {
      "t": 16.72,
      "text": " パパとママにおやすみなさい"
    },
    {
      "t": 28.07,
      "text": " せいぜい いい夢をみなさい"
    },
    {
      "t": 31.29,
      "text": " 大人はもう寝る時間よ"
    },
    {
      "t": 35.6,
      "text": " 咽返（むせかえ）る魅惑のキャラメル"
    },
    {
      "t": 39.21,
      "text": " 恥じらいの素足をからめる"
    },
    {
      "t": 42.32,
      "text": " 今夜はどこまでいけるの？"
    },
    {
      "t": 46.52,
      "text": " 噛みつかないで 優しくして"
    },
    {
      "t": 49.8,
      "text": " 苦いものはまだ嫌いなの"
    },
    {
      "t": 52.69,
      "text": " ママの作るお菓子ばかり食べたせいね"
    },
    {
      "t": 58.06,
      "text": " 知らないことがあるのならば"
    },
    {
      "t": 61.16,
      "text": " 知りたいと思う普通でしょ？"
    },
    {
      "t": 64.04,
      "text": " 全部見せてよ"
    },
    {
      "t": 65.81,
      "text": " あなたにならば見せてあげる私の..."
    },
    {
      "t": 71.07,
      "text": " ずっと恋しくてシンデレラ"
    },
    {
      "t": 74.41,
      "text": " 制服だけで駆けていくわ"
    },
    {
      "t": 77.12,
      "text": " 魔法よ時間を止めてよ"
    },
    {
      "t": 79.54,
      "text": " 悪い人に 邪魔されちゃうわ"
    },
    {
      "t": 82.54,
      "text": " 逃げ出したいのジュリエット"
    },
    {
      "t": 85.31,
      "text": " でもその名前で呼ばないで"
    },
    {
      "t": 88.15,
      "text": " そうよね 結ばれなくちゃね"
    },
    {
      "t": 91.08,
      "text": " そうじゃないと楽しくないわ"
    },
    {
      "t": 93.93,
      "text": " ねぇ私と生きてくれる？"
    },
    {
      "t": 99.56,
      "text": " 背伸びをした長いマスカラ"
    },
    {
      "t": 113.95,
      "text": " いい子になるよきっと明日から"
    },
    {
      "t": 116.79,
      "text": " 今だけ私を許して"
    },
    {
      "t": 121.02,
      "text": " 黒いレースの境界線"
    },
    {
      "t": 125.36,
      "text": " 守る人は今日はいません"
    },
    {
      "t": 128.47,
      "text": " 越えたらどこまでいけるの？"
    },
    {
      "t": 132.75,
      "text": " 噛みつくほどに 痛いほどに"
    },
    {
      "t": 136.06,
      "text": " 好きになってたのは私でしょ"
    },
    {
      "t": 138.8,
      "text": " パパはでもねあなたのこと嫌いみたい"
    },
    {
      "t": 144.17,
      "text": " 私のためと差し出す手に"
    },
    {
      "t": 147.83,
      "text": " 握ってるそれは首輪でしょ"
    },
    {
      "t": 150.3,
      "text": " 連れ出してよ 私のロミオ"
    },
    {
      "t": 153.47,
      "text": " 叱られるほど遠くへ"
    },
    {
      "t": 156.85,
      "text": " 鐘が鳴り響くシンデレラ"
    },
    {
      "t": 159.72,
      "text": " ガラスの靴は置いていくわ"
    },
    {
      "t": 163.3,
      "text": " だからね 早く見つけてね"
    },
    {
      "t": 165.75,
      "text": " 悪い夢に 焦らされちゃうわ"
    },
    {
      "t": 168.71,
      "text": " きっとあの子もそうだった"
    },
    {
      "t": 171.57,
      "text": " 落としたなんて嘘をついた"
    },
    {
      "t": 174.71,
      "text": " そうよね 私も同じよ"
    },
    {
      "t": 176.96,
      "text": " だってもっと愛されたいわ"
    },
    {
      "t": 179.78,
      "text": " ほら 私はここにいるよ"
    },
    {
      "t": 192.39,
      "text": " 私の心そっと覗いてみませんか"
    },
    {
      "t": 202.97,
      "text": " 欲しいものだけあふれかえっていませんか"
    },
    {
      "t": 208.5,
      "text": " まだ別腹よもっともっとぎゅっと詰め込んで"
    },
    {
      "t": 214.23,
      "text": " いっそあなたの居場所までも埋めてしまおうか"
    },
    {
      "t": 219.51,
      "text": " でもそれじゃ意味ないの"
    },
    {
      "t": 224.81,
      "text": " 大きな箱より 小さな箱に幸せはあるらしい"
    },
    {
      "t": 231.08,
      "text": " どうしよこのままじゃ私は"
    },
    {
      "t": 233.7,
      "text": " あなたに嫌われちゃうわ"
    },
    {
      "t": 236.45,
      "text": " でも私より欲張りなパパとママは今日も変わらず"
    },
    {
      "t": 242.55,
      "text": " そうよね 素直でいいのね"
    },
    {
      "t": 244.75,
      "text": " 落としたのは金の斧でした"
    },
    {
      "t": 247.65,
      "text": " 嘘つきすぎたシンデレラ"
    },
    {
      "t": 250.38,
      "text": " オオカミに食べられたらしい"
    },
    {
      "t": 253.32,
      "text": " どうしようこのままじゃ私も"
    },
    {
      "t": 256.32,
      "text": " いつかは食べられちゃうわ"
    },
    {
      "t": 258.93,
      "text": " その前に助けに来てね"
    },
    {
      "t": 266.08,
      "text": " "
    }
  ]
}