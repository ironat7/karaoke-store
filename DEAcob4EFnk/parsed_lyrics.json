{
 "11123587": [
  {
   "t": 1.38,
   "text": "私の恋を悲劇のジュリエットにしないで"
  },
  {
   "t": 6.94,
   "text": "ここから連れ出して..."
  },
  {
   "t": 11.08,
   "text": "そんな気分よ"
  },
  {
   "t": 14.04,
   "text": "パパとママにおやすみなさい"
  },
  {
   "t": 27.24,
   "text": "せいぜい いい夢をみなさい"
  },
  {
   "t": 29.69,
   "text": "大人はもう寝る時間よ"
  },
  {
   "t": 33.79,
   "text": "咽返る魅惑のキャラメル"
  },
  {
   "t": 38.15,
   "text": "恥じらいの素足をからめる"
  },
  {
   "t": 40.94,
   "text": "今夜はどこまでいけるの？"
  },
  {
   "t": 45.61,
   "text": "噛みつかないで 優しくして"
  },
  {
   "t": 48.33,
   "text": "苦いものはまだ嫌いなの"
  },
  {
   "t": 51.56,
   "text": "ママの作るお菓子ばかり食べたせいね"
  },
  {
   "t": 56.55,
   "text": "知らないことがあるのならば"
  },
  {
   "t": 60.95,
   "text": "知りたいと思う 普通でしょ？"
  },
  {
   "t": 63.3,
   "text": "全部見せてよ"
  },
  {
   "t": 66.86,
   "text": "あなたにならば見せてあげる私の..."
  },
  {
   "t": 70.6,
   "text": "ずっと恋しくてシンデレラ"
  },
  {
   "t": 73.19,
   "text": "制服だけで駆けていくわ"
  },
  {
   "t": 75.97,
   "text": "魔法よ時間を止めてよ"
  },
  {
   "t": 78.89,
   "text": "悪い人に邪魔されちゃうわ"
  },
  {
   "t": 81.67,
   "text": "逃げ出したいのジュリエット"
  },
  {
   "t": 84.52,
   "text": "でもその名前で呼ばないで"
  },
  {
   "t": 87.32,
   "text": "そうよね 結ばれなくちゃね"
  },
  {
   "t": 90.17,
   "text": "そうじゃないと楽しくないわ"
  },
  {
   "t": 92.86,
   "text": "ねえ 私と生きてくれる？"
  },
  {
   "t": 110.54,
   "text": "私の心そっと覗いてみませんか"
  },
  {
   "t": 113.06,
   "text": "欲しいものだけあふれかえっていませんか"
  },
  {
   "t": 115.51,
   "text": "まだ別腹よもっともっとぎゅっと詰め込んで"
  },
  {
   "t": 119.66,
   "text": "いっそあなたの居場所までも埋めてしまおうか"
  },
  {
   "t": 124.48,
   "text": "でもそれじゃ意味ないの"
  },
  {
   "t": 126.96,
   "text": "大きな箱より"
  },
  {
   "t": 133.35,
   "text": "小さな箱に幸せはあるらしい"
  },
  {
   "t": 135.74,
   "text": "どうしよう このままじゃ私は"
  },
  {
   "t": 138.64,
   "text": "あなたに嫌われちゃうわ"
  },
  {
   "t": 143.4,
   "text": "でも私より欲張りなパパとママは今日も変わらず"
  },
  {
   "t": 147.19,
   "text": "そうよね 素直でいいのね"
  },
  {
   "t": 150.54,
   "text": "落としたのは金の斧でした"
  },
  {
   "t": 156.69,
   "text": "嘘つきすぎたシンデレラ"
  },
  {
   "t": 160.13,
   "text": "オオカミに食べられたらしい"
  },
  {
   "t": 163.19,
   "text": "どうしよう このままじゃ私も"
  },
  {
   "t": 167.71,
   "text": "いつかは食べられちゃうわ"
  },
  {
   "t": 170.46,
   "text": "その前に助けに来てね"
  }
 ]
}