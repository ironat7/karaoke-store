      "t": 0.06,
      "text": "To you, yes my love to you"
    },
    {
      "t": 6.85,
      "text": "Yes my love to you, you to you"
    },
    {
      "t": 22.93,
      "text": "私は私 貴方は貴方と"
    },
    {
      "t": 31.95,
      "text": "昨夜言ってた そんな気もするわ"
    },
    {
      "t": 39.65,
      "text": "グレイのジャケットに"
    },
    {
      "t": 44.2,
      "text": "見覚えがある コーヒーのしみ"
    },
    {
      "t": 50.26,
      "text": "相変らずなのね"
    },
    {
      "t": 53.37,
      "text": "ショーウィンドウに 二人映れば"
    },
    {
      "t": 61.21,
      "text": "Stay with me..."
    },
    {
      "t": 63.68,
      "text": "真夜中のドアをたたき"
    },
    {
      "t": 68.26,
      "text": "帰らないでと泣いた"
    },
    {
      "t": 74.61,
      "text": "あの季節が 今 目の前"
