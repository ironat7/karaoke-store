{
  "11406596": [
    {
      "t": 0.78,
      "text": "時には誰かを"
    },
    {
      "t": 5.04,
      "text": "知らず知らずのうちに"
    },
    {
      "t": 8.58,
      "text": "傷つけてしまったり"
    },
    {
      "t": 13.12,
      "text": "失ったりして初めて"
    },
    {
      "t": 17.85,
      "text": "犯した罪を知る"
    },
    {
      "t": 23.56,
      "text": "戻れないよ、昔のようには"
    },
    {
      "t": 28.21,
      "text": "煌めいて見えたとしても"
    },
    {
      "t": 33.95,
      "text": "明日へと歩き出さなきゃ"
    },
    {
      "t": 38.95,
      "text": "雪が降りしきろうとも"
    },
    {
      "t": 45.73,
      "text": "今の僕には"
    },
    {
      "t": 47.28,
      "text": "何ができるの？"
    },
    {
      "t": 48.54,
      "text": "何になれるの？"
    },
    {
      "t": 49.79,
      "text": "誰かのために生きるなら"
    },
    {
      "t": 53.02,
      "text": "正しいことばかり"
    },
    {
      "t": 54.54,
      "text": "言ってらんないよな"
    },
    {
      "t": 56.28,
      "text": "どこかの街で"
    },
    {
      "t": 57.45,
      "text": "また出逢えたら"
    },
    {
      "t": 58.73,
      "text": "僕の名前を"
    },
    {
      "t": 60.03,
      "text": "覚えていますか？"
    },
    {
      "t": 61.58,
      "text": "その頃にはきっと"
    },
    {
      "t": 64.55,
      "text": "春風が吹くだろう"
    },
    {
      "t": 68.65,
      "text": "真っ新に生まれ変わって"
    },
    {
      "t": 71.17,
      "text": "人生一から始めようが"
    },
    {
      "t": 73.82,
      "text": "へばりついて離れない"
    },
    {
      "t": 76.21,
      "text": "地続きの今を歩いているんだ"
    },
    {
      "t": 79.11,
      "text": "真っ白に全てさよなら"
    },
    {
      "t": 81.44,
      "text": "降りしきる雪よ"
    },
    {
      "t": 83.26,
      "text": "全てを包み込んでくれ"
    },
    {
      "t": 85.92,
      "text": "今日だけは"
    },
    {
      "t": 86.92,
      "text": "全てを隠してくれ"
    },
    {
      "t": 100.53,
      "text": "もう戻れないよ、昔のようには"
    },
    {
      "t": 105.81,
      "text": "羨んでしまったとしても"
    },
    {
      "t": 111.17,
      "text": "明日へと歩き出さなきゃ"
    },
    {
      "t": 116.02,
      "text": "雪が降りしきろうとも"
    },
    {
      "t": 123.03,
      "text": "いつものように笑ってたんだ"
    },
    {
      "t": 125.83,
      "text": "分かり合えると思ってたんだ"
    },
    {
      "t": 128.68,
      "text": "曖昧なサインを見落として"
    },
    {
      "t": 131.35,
      "text": "途方のない間違い探し"
    },
    {
      "t": 133.79,
      "text": "季節を越えて"
    },
    {
      "t": 135.04,
      "text": "また出逢えたら"
    },
    {
      "t": 136.39,
      "text": "君の名前を"
    },
    {
      "t": 137.47,
      "text": "呼んでもいいかな"
    },
    {
      "t": 138.99,
      "text": "その頃にはきっと"
    },
    {
      "t": 141.38,
      "text": "春風が吹くだろう"
    },
    {
      "t": 146.1,
      "text": "真っ新に生まれ変わって"
    },
    {
      "t": 148.63,
      "text": "人生一から始めようが"
    },
    {
      "t": 151.18,
      "text": "首の皮一枚繋がった"
    },
    {
      "t": 153.66,
      "text": "どうしようもない今を"
    },
    {
      "t": 155.56,
      "text": "生きていくんだ"
    },
    {
      "t": 156.51,
      "text": "真っ白に全てさよなら"
    },
    {
      "t": 158.94,
      "text": "降りしきる雪よ"
    },
    {
      "t": 160.93,
      "text": "今だけはこの心を凍らせてくれ"
    },
    {
      "t": 164.27,
      "text": "全てを忘れさせてくれよ"
    },
    {
      "t": 190.21,
      "text": "朝目覚めたら"
    },
    {
      "t": 191.65,
      "text": "どっかの誰かに"
    },
    {
      "t": 193.48,
      "text": "なってやしないかな"
    },
    {
      "t": 196.33,
      "text": "なれやしないよな"
    },
    {
      "t": 199.09,
      "text": "聞き流してくれ"
    },
    {
      "t": 200.85,
      "text": "忙しない日常の中で"
    },
    {
      "t": 203.56,
      "text": "歳だけを重ねた"
    },
    {
      "t": 206.51,
      "text": "その向こう側に"
    },
    {
      "t": 209.08,
      "text": "待ち受けるのは"
    },
    {
      "t": 210.37,
      "text": "天国か地獄か"
    },
    {
      "t": 212.79,
      "text": "いつだって人は鈍感だもの"
    },
    {
      "t": 215.71,
      "text": "わかりゃしないんだ肚の中"
    },
    {
      "t": 218.2,
      "text": "それでも愛し愛され"
    },
    {
      "t": 220.52,
      "text": "生きて行くのが定めと知って"
    },
    {
      "t": 223.79,
      "text": "後悔ばかりの人生だ"
    },
    {
      "t": 225.76,
      "text": "取り返しのつかない過ちの"
    },
    {
      "t": 228.72,
      "text": "一つや二つくらい"
    },
    {
      "t": 230.33,
      "text": "誰にでもあるよな"
    },
    {
      "t": 232.85,
      "text": "そんなんもんだろう"
    },
    {
      "t": 235.1,
      "text": "うんざりするよ"
    },
    {
