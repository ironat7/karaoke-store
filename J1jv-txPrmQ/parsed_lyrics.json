{
  "25449318": [
    {
      "t": 19.82,
      "text": "夢の続き 追いかけていたはずなのに"
    },
    {
      "t": 26.43,
      "text": "曲がりくねった 細い道 人に躓く"
    },
    {
      "t": 32.58,
      "text": "あの頃にみたいにって"
    },
    {
      "t": 34.26,
      "text": "戻りたい訳じゃないの"
    },
    {
      "t": 36.02,
      "text": "なくしてきた空を 探してる"
    },
    {
      "t": 39.52,
      "text": "分かってくれます様に"
    },
    {
      "t": 41.22,
      "text": "犠牲になった様な"
    },
    {
      "t": 42.88,
      "text": "悲しい顔は やめてよ"
    },
    {
      "t": 46.26,
      "text": "罪の最後は涙じゃないよ"
    },
    {
      "t": 48.05,
      "text": "ずっと苦しく背負ってくんだ"
    },
    {
      "t": 49.84,
      "text": "出口見えない感情迷路に"
    },
    {
      "t": 51.47,
      "text": "誰を待ってるの"
    },
    {
      "t": 53.26,
      "text": "白いノートに綴った様に"
    },
    {
      "t": 54.87,
      "text": "もっと素直に吐き出したいよ"
    },
    {
      "t": 56.67,
      "text": "何から逃れたいんだ"
    },
    {
      "t": 58.36,
      "text": "現実ってやつか"
    },
    {
      "t": 60.02,
      "text": "何の為に生きてるんだって"
    },
    {
      "t": 63.25,
      "text": "忘れちゃいそうな"
    },
    {
      "t": 64.96,
      "text": "夜の真ん中"
    },
    {
      "t": 66.73,
      "text": "無難になんてやってらんないから"
    },
    {
      "t": 71.76,
      "text": "帰る場所もないの"
    },
    {
      "t": 73.6,
      "text": "この想いを消してしまうには"
    },
    {
      "t": 77.01,
      "text": "まだ人生長いでしょ (I'm on the way)"
    },
    {
      "t": 80.39,
      "text": "懐かしくなる"
    },
    {
      "t": 82.11,
      "text": "こんな痛みも歓迎じゃん"
    },
    {
      "t": 85.39,
      "text": "​"
    },
    {
      "t": 92.1,
      "text": "謝らなくちゃいけないよね"
    },
    {
      "t": 95.88,
      "text": "ああ ごめんね"
    },
    {
      "t": 98.78,
      "text": "うまく言えなくて"
    },
    {
      "t": 100.93,
      "text": "心配かけたままだったね"
    },
    {
      "t": 104.88,
      "text": "あの日抱えた全部"
    },
    {
      "t": 106.39,
      "text": "明日抱える全部"
    },
    {
      "t": 108.11,
      "text": "順番つけたりはしないから"
    },
    {
      "t": 111.62,
      "text": "分かってくれます様に"
    },
    {
      "t": 113.24,
      "text": "そっと目を閉じたんだ"
    },
    {
      "t": 114.89,
      "text": "見たくないものまで見えんだもん"
    },
    {
      "t": 118.49,
      "text": "いらない噂にちょっと"
    },
    {
      "t": 120.22,
      "text": "初めて聞く発言どっち"
    },
    {
      "t": 121.93,
      "text": "向かい合ったら友達だって"
    },
    {
      "t": 123.55,
      "text": "嘘はやめてね"
