    {
      "t": 1.07,
      "text": "ねぇ アナタには見えない事ばかり"
    },
    {
      "t": 4.07,
      "text": "アタシは見えている事を知らないの？"
    },
    {
      "t": 6.98,
      "text": "背中につけられた誰かのキスの跡"
    },
    {
      "t": 9.94,
      "text": "一人じゃ買う訳の無いそれも"
    },
    {
      "t": 13.14,
      "text": "見て見ぬフリなだけ"
    },
    {
      "t": 16.08,
      "text": "笑っちまう程にキュートなカノジョ"
    },
    {
      "t": 19.26,
      "text": "常時奔放 狂気 短気"
    },
    {
      "t": 22.23,
      "text": "怒鳴ってたって目が合って一撃"
    },
    {
      "t": 25.18,
      "text": "洗脳完了 女上手"
    },
    {
      "t": 28.12,
      "text": "愛していんのさ 強く愛していんのさ"
    },
    {
      "t": 34.57,
      "text": "ねぇ 精神から全身まで"
    },
    {
      "t": 35.8,
      "text": "表面から内面まで"
    },
    {
      "t": 37.57,
      "text": "脳天から先端まで"
    },
    {
      "t": 39.14,
      "text": "知りたいの それから"
    },
    {
      "t": 40.46,
      "text": "最近聞いた音楽から"
    },
    {
      "t": 42.06,
      "text": "散財した総額まで"
    },
    {
      "t": 43.32,
      "text": "完全把握しないと気が済まないの"
    },
    {
      "t": 46.3,
      "text": "とやかく言ったって実際の問題は"
    },
    {
      "t": 48.14,
      "text": "その眼中アタシ何割くらい担ってるか"
    },
    {
      "t": 51.92,
      "text": "嗚呼隠してないで確信を頂戴"
    },
    {
      "t": 54.87,
      "text": "されど黙して語らず"
    },
    {
      "t": 58.02,
      "text": "困っちまう程にキュートなカノジョ"
    },
    {
      "t": 61.03,
      "text": "容姿端麗 耽美 甘美"
    },
    {
      "t": 63.95,
      "text": "身勝手だって泣くシックな素振り"
    },
    {
      "t": 67.44,
      "text": "瞬時酩酊 女冥利"
    },
    {
      "t": 70.19,
      "text": "愛しちまうのさ されど愛しちまうのさ"
    },
    {
      "t": 86.69,
      "text": "過去を喰らう程にポップなエレジー"
    },
    {
      "t": 89.7,
      "text": "排気口から香るラーメン"
    },
    {
      "t": 92.86,
      "text": "騙し奪われる恋でもいいの"
