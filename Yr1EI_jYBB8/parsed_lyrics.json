{
  "1884251": [
    {
      "t": 1.19,
      "text": "あぁ素晴らしき世界に今日も乾杯"
    },
    {
      "t": 4.74,
      "text": "街に飛び交う笑い声も"
    },
    {
      "t": 7.39,
      "text": "見て見ぬフリしてるだけの作りもんさ"
    },
    {
      "t": 11.82,
      "text": "気が触れそうだ"
    },
    {
      "t": 13.24,
      "text": "クラクラするほどの良い匂いが"
    },
    {
      "t": 15.88,
      "text": "ツンと刺した鼻の奥"
    },
    {
      "t": 18.25,
      "text": "目を覚ます本能のまま"
    },
    {
      "t": 20.13,
      "text": "今日は誰の番だ？"
    },
    {
      "t": 23.03,
      "text": "この世界で何が出来るのか"
    },
    {
      "t": 26.88,
      "text": "僕には何が出来るのか"
    },
    {
      "t": 29.85,
      "text": "ただその真っ黒な目から"
    },
    {
      "t": 32.55,
      "text": "涙溢れ落ちないように"
    },
    {
      "t": 35.57,
      "text": "あぁ願う未来に何度でもずっと"
    },
    {
      "t": 38.82,
      "text": "喰らいつく"
    },
    {
      "t": 39.91,
      "text": "この間違いだらけの世界の中"
    },
    {
      "t": 44.11,
      "text": "君には笑ってほしいから"
    },
    {
      "t": 47.34,
      "text": "もう誰も傷付けない"
    },
    {
      "t": 49.46,
      "text": "強く強くなりたいんだよ"
    },
    {
      "t": 52.12,
      "text": "僕が僕でいられるように"
    },
    {
      "t": 57.35,
      "text": ""
    },
    {
      "t": 63.82,
      "text": "素晴らしき世界は今日も安泰"
    },
    {
      "t": 66.83,
      "text": "街に渦巻く悪い話も"
    },
    {
      "t": 69.61,
      "text": "知らない知らないフリして目を逸らした"
    },
    {
      "t": 73.77,
      "text": "正気の沙汰じゃないな"
    },
    {
      "t": 75.92,
      "text": "真面目に着飾った行進"
    },
    {
      "t": 78.13,
      "text": "鳴らす足音が弾む行き先は"
    },
    {
      "t": 81.03,
      "text": "消えない消えない味が染み付いている"
    },
    {
      "t": 85.18,
      "text": "裏側の世界"
    },
    {
      "t": 88.26,
      "text": ""
    },
    {
      "t": 98.05,
      "text": "清く正しく生きること"
    },
    {
      "t": 100.49,
      "text": "誰も悲しませずに生きること"
    },
    {
      "t": 103.04,
      "text": "はみ出さず真っ直ぐに生きること"
    },
    {
      "t": 105.99,
      "text": "それが間違わないで生きること？"
    },
    {
      "t": 108.87,
      "text": "ありのまま生きることが正義か"
    },
    {
      "t": 111.58,
      "text": "騙し騙し生きるのは正義か"
    },
    {
      "t": 114.48,
      "text": "僕の在るべき姿とはなんだ"
    },
    {
      "t": 117.2,
      "text": "本当の僕は何者なんだ"
    },
    {
      "t": 119.83,
      "text": "教えてくれよ"
    },
    {
      "t": 122.86,
      "text": ""
    },
    {
      "t": 125.47,
      "text": "教えてくれよ"
    },
    {
      "t": 128.54,
      "text": ""
    },
    {
      "t": 131.16,
      "text": "今日も"
    },
    {
      "t": 131.96,
      "text": "答えのない世界の中で"
    },
    {
      "t": 134.81,
      "text": "願ってるんだよ"
    },
    {
      "t": 136.44,
      "text": "不器用だけれど"
    },
    {
