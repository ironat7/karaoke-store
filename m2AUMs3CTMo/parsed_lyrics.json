    },
    {
      "t": 215.39,
      "text": "泣くなよバカだな"
    },
    {
      "t": 218.97,
      "text": "伝えたい言葉は止めどなく溢れる"
    },
    {
      "t": 225.65,
      "text": "何度も、何度でも"
    },
    {
      "t": 229.28,
      "text": "僕は君に恋をする"
    },
    {
      "t": 236.24,
      "text": "さよなら、また会おう"
    },
    {
      "t": 239.72,
      "text": "ごめんね、好きだよ"
    },
    {
      "t": 243.02,
      "text": "さよなら、笑ってよ"
    },
    {
      "t": 246.58,
      "text": "怒んなよ、バカだな"
    },
    {
      "t": 250.17,
      "text": "恋しい 苦しい、愛しいじゃ足りない"
    },
    {
      "t": 257.04,
      "text": "何度も、何度でも"
    },
    {
      "t": 261.07,
      "text": "叫ぶよ"
    },
    {
      "t": 264.05,
      "text": "好きだよ"
    },
    {
      "t": 270.64,
      "text": "さよなら"
    },
    {
      "t": 277.12,
      "text": ""
    }
  ],
  "18761541": [
    {
      "t": 1.23,
      "text": "数年経っても 影は消えない"
    },
    {
      "t": 3.46,
      "text": "感情ばかりが 募って行く"
    },
    {
      "t": 5.5,
      "text": "蹲って 一人 描いていた"
    },
    {
      "t": 10.67,
      "text": "炎天直下 坂道の上"
    },
    {
      "t": 12.78,
      "text": "滲んだ 僕らが歩いていた"
    },
    {
      "t": 15.01,
      "text": "夏の温度が目に残っていた"
    },
    {
      "t": 18.57,
      "text": "「構わないでよ、」"
    },
    {
      "t": 20.5,
      "text": "「何処かへ行ってくれ」"
    },
    {
      "t": 22.55,
      "text": "君の手を払った"
    },
    {
      "t": 24.54,
      "text": "「行かないよ」"
    },
    {
      "t": 25.55,
      "text": "なんて言って君は"
    },
    {
      "t": 27.27,
      "text": "僕の手を掴んだ"
    },
    {
      "t": 29.47,
      "text": "「五月蝿いな」"
    },
    {
      "t": 30.64,
      "text": "僕はちょっとの先を"
    },
    {
      "t": 32.07,
      "text": "振り返ずに歩いた"
    },
    {
      "t": 34.07,
      "text": "『本当の心は?』"
    },
    {
      "t": 60.88,
      "text": "「聡明」なんかじゃ 前は向けない"
    },
    {
      "t": 62.93,
      "text": "理由が無いから 腐って行く"
    },
    {
      "t": 65.23,
      "text": "巻き戻ってくれれば良いのにな"
    },
    {
      "t": 70.09,
      "text": "何年経っても 僕は死なない"
    },
    {
      "t": 72.56,
      "text": "希望論ばかりを 唱えている"
    },
    {
      "t": 74.83,
      "text": "当然今日も君は居ないのにさ"
    },
    {
      "t": 77.97,
      "text": "「構わない、死ねよ、死ねよ」って手首を"
    },
    {
      "t": 81.82,
      "text": "握って、ただ呪って"
    },
    {
      "t": 84.16,
      "text": "何も出来ないでただ、のうのうと"
    },
    {
      "t": 86.7,
      "text": "人生を貪った"
    },
    {
      "t": 88.87,
      "text": "「夏が夢を見せるのなら、君を"
    },
    {
      "t": 91.53,
      "text": "連れ去る前へ」なんて"
    },
    {
      "t": 93.26,
      "text": "照れ隠しした日々が 空気を照らして"
    },
    {
      "t": 96.16,
      "text": "脳裏を焦がしていく"
    },
    {
      "t": 98.71,
      "text": "18歳になった少年"
    },
    {
      "t": 101.09,
      "text": "また何処かで待っていたんだ"
    },
    {
      "t": 103.23,
      "text": "カゲボウシ 滲む 姿を"
    },
    {
      "t": 105.62,
      "text": "思い出して"
    },
    {
      "t": 108.17,
      "text": "炎天下に澄んだ校庭"
    },
    {
      "t": 110.42,
      "text": "笑っていた君が今日も"
    },
    {
      "t": 112.83,
      "text": "「遊ぼうよ」って言って"
    },
    {
      "t": 114.64,
      "text": "ユラユラ揺れた"
    },
    {
      "t": 117.63,
      "text": "「心配です」と不器用な顔"
    },
    {
      "t": 120.19,
      "text": "隣人なんかには 解かんないさ"
    },
    {
      "t": 122.19,
      "text": "悲しそうなフリをしないでくれ"
    },
    {
      "t": 127.29,
      "text": "朦朧(もうろう)、今日も不自然でいよう"
    },
    {
      "t": 129.36,
      "text": "昨日のペースを守っていよう"
    },
    {
      "t": 132.06,
      "text": "君の温度を忘れない様に"
    },
    {
      "t": 134.73,
      "text": "叶わない"
    },
    {
      "t": 136.84,
      "text": "夢を願うのならいっそ"
    },
    {
      "t": 138.95,
      "text": "掠れた過去を抱いて"
    },
    {
      "t": 141.22,
      "text": "覚めない 夢を見よう"
    },
    {
      "t": 143.07,
      "text": "当然の様に 閉じ篭って"
    },
    {
      "t": 145.98,
      "text": "「それじゃあ、明日も見えないままですよ?」"
    },
    {
      "t": 148.6,
      "text": "それならそれで 良いさ"
    },
    {
      "t": 150.54,
      "text": "つまらない日々を 殺すように手を染め"
    },
    {
      "t": 153.2,
      "text": "『一人』を選ぶから"
    },
    {
      "t": 155.77,
      "text": "18歳、腐った少年"
    },
    {
      "t": 158.06,
      "text": "また今日も祈っていたんだ"
    },
    {
      "t": 160.47,
      "text": "色めいた 君の笑顔に"
    },
    {
      "t": 163.17,
      "text": "しがみついて"
    },
    {
      "t": 165.53,
      "text": "炎天下に「どうかいっそ"
    },
    {
      "t": 167.6,
      "text": "連れてってくれよ」なんて"
    },
    {
      "t": 170.43,
      "text": "呟いて息を静かに止めた"
    },
    {
      "t": 178.5,
      "text": "(戻らない)"
    },
    {
      "t": 181.92,
      "text": "(あの日が)"
    },
    {
      "t": 184.03,
      "text": "(いたくて)"
    },
    {
      "t": 185.84,
      "text": "(誰も触れないで)"
    },
    {
      "t": 198.94,
      "text": "「聞こえていますか」と 声が消えた"
    },
    {
      "t": 207.71,
      "text": "理由もなんだか分かっていた"
    },
    {
      "t": 212.76,
      "text": "夏の温度に手を伸ばしていた"
    },
    {
      "t": 236.48,
      "text": "炎天下、願った少年"
    },
    {
      "t": 239.96,
      "text": "「あの頃」に立っていたんだ"
    },
    {
      "t": 242.49,
      "text": "夏めく君の 笑顔は"
    },
    {
      "t": 244.97,
      "text": "変わらなくて"
    },
    {
      "t": 247.35,
      "text": "「死んじゃった。ごめんね」なんて"
    },
    {
      "t": 249.08,
      "text": "「『サヨウナラ』しようか」なんて"
    },
    {
      "t": 251.84,
      "text": "寂しいこと言わないで"
    },
    {
      "t": 254.42,
      "text": "往かないで"
    },
    {
      "t": 256.82,
      "text": "カゲボウシが そんな僕を"
    },
    {
      "t": 259.18,
      "text": "見つめていたんだ"
    },
    {
      "t": 264.37,
      "text": ""
    }
  ],
  "1883787": [
    {
      "t": 0.42,
      "text": "その日は随分と平凡で"
    },
    {
      "t": 2.45,
      "text": "当たり障り無い一日だった"
    },
    {
      "t": 4.75,
      "text": "暇つぶしに聞いてたラジオから"
    },
    {
      "t": 7.18,
      "text": "あの話が流れ出すまでは"
    },
    {
      "t": 9.37,
      "text": "「非常に残念なことですが、"
    },
    {
      "t": 11.86,
      "text": "本日地球は終わります」と"
    },
    {
      "t": 14.57,
      "text": "どこかの国の大統領が"
    },
    {
      "t": 16.37,
      "text": "泣きながら話をするまでは。"
    },
    {
      "t": 46.02,
      "text": "窓の外は大きな鳥たちが"
    },
    {
      "t": 48.11,
      "text": "空覆い尽くしてく渋滞中"
    },
    {
      "t": 50.25,
      "text": "三日月を飲み込んで"
    },
    {
      "t": 52.14,
      "text": "どこかへと向かってる"
    },
    {
      "t": 55.08,
      "text": "やりかけてたゲームはノーセーブ"
    },
    {
      "t": 57.35,
      "text": "机にほぼ手つかず参考書"
    },
    {
      "t": 59.29,
      "text": "震える身体をいなす様に"
    },
    {
      "t": 62.52,
      "text": "すぐにヘッドフォンをした"
    },
    {
      "t": 65.18,
      "text": "不明なアーティスト項目の"
    },
    {
      "t": 67.03,
      "text": "タイトル不明のナンバーが"
    },
    {
      "t": 69.08,
      "text": "途端に耳元流れ出した"
    },
    {
      "t": 71.55,
      "text": "「生き残りたいでしょう？」"
    },
    {
      "t": 74.03,
      "text": "蠢きだす世界会場を"
    },
    {
      "t": 75.87,
      "text": "波打つように揺れる摩天楼"
    },
    {
      "t": 78.38,
      "text": "紛れもないこの声はどう聞いても"
    },
    {
      "t": 80.25,
      "text": "聞き飽きた自分の声だ"
    },
    {
      "t": 82.06,
      "text": "「あの丘を越えたら20秒で"
    },
    {
      "t": 84.66,
      "text": "その意味を嫌でも知ることになるよ。"
    },
    {
      "t": 87.55,
      "text": "疑わないで、耳を澄ませたら20秒先へ」"
    },
    {
      "t": 102.46,
      "text": "交差点は当然大渋滞"
    },
    {
      "t": 104.52,
      "text": "もう老若男女は関係ない"
    },
    {
      "t": 106.89,
      "text": "怒号やら赤ん坊の泣き声で埋まっていく"
    },
    {
      "t": 110.33,
      "text": "暴れだす人 泣き出す少女"
    },
    {
      "t": 113.95,
      "text": "祈りだした神父を追い抜いて"
    },
    {
      "t": 116.34,
      "text": "ただ一人目指すのは逆方向"
    },
    {
      "t": 118.48,
      "text": "あの丘の向こうへと"
    },
    {
      "t": 121.03,
      "text": "ヘッドフォンから依然声がして"
    },
    {
      "t": 123.02,
      "text": "「あと12分だよ」と告げる"
    },
    {
      "t": 125.44,
      "text": "このまま全て消え去ってしまうなら"
    },
    {
      "t": 128.11,
      "text": "もう術は無いだろう"
    },
    {
      "t": 129.98,
      "text": "ざわめき出す悲鳴合唱を"
    },
    {
      "t": 132.07,
      "text": "涙目になってかすめる10秒"
    },
    {
      "t": 134.42,
      "text": "疑いたいけど誰がどうやっても"
    },
    {
      "t": 137.23,
      "text": "終わらない人類賛歌"
    },
    {
      "t": 138.72,
      "text": "「駆け抜けろ, もう残り１分だ。」"
    },
    {
      "t": 141.51,
      "text": "その言葉ももう聞こえない位に"
    },
    {
      "t": 143.89,
      "text": "ただ目指していた丘の向こうは"
    },
    {
      "t": 146.41,
      "text": "すぐ目の前に"
    },
    {
      "t": 148.33,
      "text": "息も絶え絶えたどり着いたんだ"
    },
    {
      "t": 151.28,
      "text": "空を映し出す壁の前に"
    },
    {
      "t": 153.46,
      "text": "その向こう白衣の科学者たちは"
    },
    {
      "t": 156.02,
      "text": "「素晴らしい」と手を打った"
    },
    {
      "t": 157.82,
      "text": "疑うよ。"
    },
    {
      "t": 158.98,
      "text": "そこから見る街の風景は"
    },
    {
      "t": 161.29,
      "text": "まるで実験施設の様でさ"
    },
    {
      "t": 163.3,
      "text": "「もう不必要だ。」"
    },
    {
      "t": 165.93,
      "text": "科学者は片手間に爆弾を投げた"
    },
    {
      "t": 168.16,
      "text": "箱の中の小さな世界で"
    },
    {
      "t": 170.56,
      "text": "今までずっと生きてきたんだなと"
    },
    {
      "t": 173.09,
      "text": "燃え尽きていく街だったモノを"
    },
    {
      "t": 176.52,
      "text": "ただ、呆然と見る耳元で"
    },
    {
      "t": 178.48,
      "text": "ヘッドフォンの向こうから"
    },
    {
      "t": 180.28,
      "text": "「ごめんね」と声がした"
    },
    {
      "t": 191.86,
      "text": ""
    }
  ],
  "2493015": [
    {
      "t": 15.96,
      "text": "コンクリートが揺らいだ"
    },
    {
      "t": 17.82,
      "text": "霞み燻む、君の望ている夢"
    },
    {
      "t": 20.49,
      "text": "テンプレートをなぞった"
    },
    {
      "t": 22.73,
      "text": "知らないままの日常"
    },
    {
      "t": 25.32,
      "text": "ハイテンポなアテンダンス"
    },
    {
      "t": 27.67,
      "text": "消えない 足りない 落ち込んだ未来"
    },
    {
      "t": 31.42,
      "text": "最終話が来たって"
    },
    {
      "t": 33.74,
      "text": "言えない 君は泣きそう"
    },
    {
      "t": 36.24,
      "text": "ほら、目を閉じて 迷子なら一緒"
    },
    {
      "t": 38.73,
      "text": "帰り道もないでしょう?"
    },
    {
      "t": 40.5,
      "text": "継ぎ接いでた 秘密に願う 未来は平凡"
    },
    {
      "t": 44.29,
      "text": "さぁ、手を鳴らせ"
    },
    {
      "t": 45.99,
      "text": "0で廻った 勘違いを今日も集めて"
    },
    {
      "t": 48.96,
      "text": "始めよう 君もまた、無我夢中?"
    },
    {
      "t": 54.36,
      "text": "Let's「play」 届くまで叫んで"
    },
    {
      "t": 56.53,
      "text": "Let's「save」 叶うまで足掻いて"
    },
    {
      "t": 59.24,
      "text": "その手を掴むまで この温度は忘れない"
    },
    {
      "t": 63.94,
      "text": "Let's「daze」 心を消さないで"
    },
    {
      "t": 66.32,
      "text": "Let's「change」 一人で泣かないで"
    },
    {
      "t": 68.77,
      "text": "「孤独」なら塗り替えれる"
    },
    {
      "t": 71.48,
      "text": "思い出してよ 言いたかったこと"
    },
    {
      "t": 75.58,
      "text": ""
    },
    {
      "t": 83.9,
      "text": "アンコールが響いた"
    },
    {
      "t": 85.54,
      "text": "巡り廻る、街の中を往け"
    },
    {
      "t": 87.8,
      "text": "スタンダードを壊して"
    },
    {
      "t": 89.77,
      "text": "汗ばんだ手を 繋ごう"
    },
    {
      "t": 92.26,
      "text": "ブレイクアウトとスタンドアップ"
    },
    {
      "t": 94.77,
      "text": "寝れない 止めない 逆襲の気配"
    },
    {
      "t": 97.57,
      "text": "最終日が来たって"
    },
    {
      "t": 99.63,
      "text": "消えない 言葉探そう"
    },
    {
      "t": 101.6,
      "text": "ほら、手を出して 会えたのはきっと"
    },
    {
      "t": 104.23,
      "text": "思い違いじゃないでしょう?"
    },
    {
      "t": 106.2,
      "text": "影法師の随に 憂う世界は残像"
    },
    {
      "t": 109.92,
      "text": "もう「悔しさ」も「弱さ」も"
    },
    {
      "t": 112.53,
      "text": "いっそ「意気地なし」も全部含めて"
    },
    {
      "t": 116.14,
      "text": "飛ひ込もう 君もまた、無我夢中?"
    },
    {
      "t": 122.14,
      "text": "Let's「play」 伸ばす手が揺らいで"
    },
    {
      "t": 124.71,
      "text": "Let's「save」 心もすり減って"
    },
    {
      "t": 127.06,
      "text": "まるで希望がなくったって その温度は忘れない"
    },
    {
      "t": 131.88,
      "text": "Let's「daze」 街風が唸って"
    },
    {
      "t": 134.26,
      "text": "Let's「change」 言葉が消えたって"
    },
    {
      "t": 136.79,
      "text": "「気持ち」なら 此処にある"
    },
    {
      "t": 139.07,
      "text": "ずっと前から 気付いてたんだよ"
    },
    {
      "t": 143.24,
      "text": ""
    },
    {
      "t": 151.35,
      "text": "赤い目擦ったあの子へと"
    },
    {
      "t": 153.98,
      "text": "青い青い夏を超えて"
    },
    {
      "t": 156.25,
      "text": "届くのが この声なら"
    },
    {
      "t": 160.82,
      "text": "「さよなら」唱えた 夕暮れも"
    },
    {
      "t": 163.52,
      "text": "また昨日に変えれる"
    },
    {
      "t": 165.88,
      "text": "この夢を抜け出せる きっと"
    },
    {
      "t": 171.77,
      "text": "待って 一人なら応えて"
    },
    {
      "t": 174.44,
      "text": "今日を嘆いたりしないで"
    },
    {
      "t": 176.86,
      "text": "寂しさも 涙も"
    },
    {
      "t": 179.15,
      "text": "分け合うから 一緒に"
    },
    {
      "t": 181.74,
      "text": "Let's「play」 届くまで叫んで"
    },
    {
      "t": 184.1,
      "text": "Let's「save」 叶うまで足掻いて"
    },
    {
      "t": 186.46,
      "text": "その手を掴むまで この温度は忘れない"
    },
    {
