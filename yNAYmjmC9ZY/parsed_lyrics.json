    {
      "t": 166.48,
      "text": "好きよ今日まで"
    },
    {
      "t": 168.75,
      "text": "逢った誰より"
    },
    {
      "t": 171.24,
      "text": "I will follow you あなたの"
    },
    {
      "t": 174.2,
      "text": "生き方が好き"
    },
    {
      "t": 176.79,
      "text": "このまま帰れない 帰れない"
    },
    {
      "t": 186.02,
      "text": "心に春が来た日は 赤いスイートピー"
    }
