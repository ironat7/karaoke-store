  "3821917": [
    {
      "t": 32.13,
      "text": "君とのラブストーリー"
    },
    {
      "t": 35.43,
      "text": "それは予想通り"
    },
    {
      "t": 38.24,
      "text": "いざ始まればひとり芝居だ"
    },
    {
      "t": 42.37,
      "text": "ずっとそばにいたって"
    },
    {
      "t": 44.85,
      "text": "結局ただの観客だ"
    },
    {
      "t": 47.89,
      "text": "感情のないアイムソーリー"
    },
    {
      "t": 51.08,
      "text": "それはいつも通り"
    },
    {
      "t": 53.63,
      "text": "慣れてしまえば悪くはないけど"
    },
    {
      "t": 57.86,
      "text": "君とのロマンスは人生柄"
    },
    {
      "t": 61.6,
      "text": "続きはしないことを知った"
    },
    {
      "t": 68.47,
      "text": "もっと違う設定で もっと違う関係で"
    },
    {
      "t": 73.58,
      "text": "出会える世界線 選べたらよかった"
    },
    {
      "t": 78.81,
      "text": "もっと違う性格で もっと違う価値観で"
    },
    {
      "t": 84.07,
      "text": "愛を伝えられたらいいな そう願っても無駄だから"
    },
    {
      "t": 93.9,
      "text": "グッバイ"
    },
    {
      "t": 95.05,
      "text": "君の運命のヒトは僕じゃない"
    },
    {
      "t": 99.64,
      "text": "辛いけど否めない でも離れ難いのさ"
    },
    {
      "t": 105.85,
      "text": "その髪に触れただけで 痛いや"
    },
    {
      "t": 111.27,
      "text": "いやでも 甘いな いやいや"
    },
    {
      "t": 114.77,
      "text": "グッバイ"
    },
    {
      "t": 115.54,
      "text": "それじゃ僕にとって君は何？"
    },
    {
      "t": 120.37,
      "text": "答えは分からない 分かりたくもないのさ"
    },
    {
      "t": 126.67,
      "text": "たったひとつ確かなことがあるとするのならば"
    },
    {
      "t": 134.78,
      "text": "「君は綺麗だ」"
    },
    {
      "t": 141.93,
      "text": "誰かが偉そうに"
    },
    {
      "t": 144.83,
      "text": "語る恋愛の論理"
    },
    {
      "t": 147.58,
      "text": "何ひとつとしてピンとこなくて"
    },
    {
      "t": 151.76,
      "text": "飛行機の窓から見下ろした"
    },
    {
      "t": 155.43,
      "text": "知らない街の夜景みたいだ"
    },
    {
      "t": 162.38,
      "text": "もっと違う設定で もっと違う関係で"
    },
    {
      "t": 167.32,
      "text": "出会える世界線 選べたらよかった"
    },
    {
      "t": 172.76,
      "text": "いたって純な心で 叶った恋を抱きしめて"
    },
    {
      "t": 177.7,
      "text": "「好きだ」とか無責任に言えたらいいな"
    },
    {
      "t": 182.47,
      "text": "そう願っても虚しいのさ"
    },
    {
      "t": 187.93,
      "text": "グッバイ"
    },
    {
      "t": 188.66,
      "text": "繋いだ手の向こうにエンドライン"
    },
    {
      "t": 193.56,
      "text": "引き伸ばすたびに 疼きだす未来には"
