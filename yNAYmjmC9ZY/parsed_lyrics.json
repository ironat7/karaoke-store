    },
    {
      "t": 139.77,
      "text": "I will follow you 翼の"
    },
    {
      "t": 143.0,
      "text": "生えたブーツで"
    },
    {
      "t": 145.59,
      "text": "I will follow you あなたと"
    },
    {
      "t": 148.7,
      "text": "同じ青春"
    },
    {
      "t": 151.23,
      "text": "走ってゆきたいの"
    },
    {
      "t": 157.53,
      "text": "線路の脇のつぼみは 赤いスイートピー"
